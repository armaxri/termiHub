{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "termiHub",
  "version": "0.1.0",
  "identifier": "com.termihub.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "termiHub",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "backgroundColor": "#1e1e1e",
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "termiHub — cross-platform terminal hub",
      "args": [
        {
          "name": "workspace",
          "short": "w",
          "takesValue": true,
          "description": "Launch a workspace by name"
        },
        {
          "name": "workspace-file",
          "takesValue": true,
          "description": "Launch a workspace from a JSON definition file"
        },
        {
          "name": "list-workspaces",
          "takesValue": false,
          "description": "List all saved workspaces and exit"
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

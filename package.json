{
  "name": "termihub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"docs/**/*.md\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"docs/**/*.md\" \"*.md\"",
    "markdownlint": "markdownlint-cli2 \"docs/**/*.md\" \"*.md\"",
    "markdownlint:fix": "markdownlint-cli2 --fix \"docs/**/*.md\" \"*.md\"",
    "test:e2e": "wdio run ./wdio.conf.js",
    "test:e2e:ui": "wdio run ./wdio.conf.js --suite ui",
    "test:e2e:local": "wdio run ./wdio.conf.js --suite local",
    "test:e2e:infra": "wdio run ./wdio.conf.js --suite infra",
    "test:e2e:perf": "wdio run ./wdio.conf.js --suite perf"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lucide/lab": "^0.1.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@shikijs/monaco": "^4.0.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.563.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.1",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.6.2",
    "react-virtuoso": "^4.18.1",
    "shiki": "^4.0.2",
    "zustand": "^5.0.11"
  },
  "pnpm": {
    "overrides": {
      "dompurify": ">=3.4.0",
      "serialize-javascript": ">=7.0.5",
      "flatted": ">=3.4.2",
      "fast-uri": ">=3.1.2",
      "rollup": ">=4.59.0",
      "postcss": ">=8.5.10",
      "undici": ">=7.24.0",
      "vite>picomatch": ">=4.0.4",
      "vitest>picomatch": ">=4.0.4",
      "anymatch>picomatch": "2.3.2",
      "readdirp>picomatch": "2.3.2",
      "micromatch>picomatch": "2.3.2",
      "minimatch@3>brace-expansion": "1.1.14",
      "minimatch@5>brace-expansion": ">=2.0.3"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "edgedriver",
      "geckodriver"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@eslint/js": "^9.39.2",
    "@tauri-apps/cli": "^2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.5",
    "@wdio/cli": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^28.1.0",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  }
}
